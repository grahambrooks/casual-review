    byte_range:
      start: 58
      end: 71
    line_start: 3
    col_start: 5
    line_end: 3
    col_end: 18
  helps:
    - address the underlying type error or narrow the assertion
- code: ts-escape-hatch
  severity: warning
  message: "non-null assertion (`!`) bypasses the null check"
